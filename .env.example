# ── Firebase web config (client-side, exposed in the bundle; NOT secrets) ──
# Copy this file to `.env.local` and fill in the six values from:
#   Firebase console → Project settings → General → Your apps → Web app
#   → "SDK setup and configuration" → Config
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"

# ── Server-side secrets (NOT prefixed with VITE_, never sent to the client) ──
# GEMINI_API_KEY: AI Studio (Gemini API) key. Used when GEMINI_BACKEND=aistudio.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL: the URL where this app is hosted (self-referential links, OAuth callbacks).
APP_URL="MY_APP_URL"

# ── Gemini backend selector (server.ts makeGenAI) ──────────────────────────
# Picks which @google/genai backend server.ts talks to. All call sites are
# identical across backends — only the client construction changes.
#   aistudio        → Gemini API, uses GEMINI_API_KEY            (default)
#   vertex-express  → Vertex AI Express mode, uses VERTEX_API_KEY
#   vertex          → Vertex AI, uses ADC + project/location (no key)
GEMINI_BACKEND="aistudio"

# vertex-express: an Express-mode API key from Vertex AI Studio.
VERTEX_API_KEY="MY_VERTEX_API_KEY"

# vertex (full): Application Default Credentials auth (no API key). On App Hosting
# the runtime service account is used automatically (grant it roles/aiplatform.user).
GOOGLE_CLOUD_PROJECT="MY_GCP_PROJECT_ID"
VERTEX_LOCATION="us-central1"
# Local dev only: absolute path to a service-account JSON key that has
# roles/aiplatform.user. The Google auth library reads this automatically.
# Keep the key file OUTSIDE the repo (or gitignored) — never commit it.
# Leave UNSET in production.
GOOGLE_APPLICATION_CREDENTIALS="C:/keys/finia-vertex-sa.json"
